# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# Optional owner-only mode: set to your Telegram user id.
# If empty, everyone can use the bot.
TELEGRAM_USER_ID=

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/airdeal.db

# Providers
TRAVELOKA_AFFILIATE_ID=
TRIP_AFFILIATE_ID=

# fast-flights (Google Flights data, không cần key)
FAST_FLIGHTS_ENABLED=true

# Atadi (cần API key — email dev@atadi.vn với mã TKTT của bạn)
ATADI_ENABLED=false
ATADI_API_KEY=

# Atadi Web scraper (Playwright, không cần key - bật mặc định)
ATADI_WEB_ENABLED=true
# Dùng CloakBrowser thay Playwright để tránh bị Atadi detect/block (+200MB)
ATADI_USE_CLOAK=false

# Worker / limits
PRICE_SCAN_INTERVAL_MINUTES=60
SEARCH_CACHE_TTL_MINUTES=30
MAX_ALERTS_PER_USER_PER_DAY=10
RATE_LIMIT_PER_MINUTE=20

# Logging
LOG_LEVEL=INFO
HTTP_PORT=8080
